{
  "manifest_version": 3,
  "name": "Getify Ads Spy",
  "version": "1.0.0",
  "description": "Passively captures Etsy Ads API responses for analytics",
  "browser_specific_settings": {
    "gecko": {
      "id": "getify-ads-spy@getify.ai",
      "strict_min_version": "128.0"
    }
  },
  "permissions": ["storage", "webNavigation", "tabs"],
  "host_permissions": [
    "https://*.neon.tech/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.etsy.com/*"],
      "js": ["interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["*://*.etsy.com/*"],
      "js": ["bridge.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    },
    {
      "matches": ["*://*.etsy.com/your/shops/*/advertising/listings/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "world": "ISOLATED"
    }
  ],
  "background": {
    "scripts": ["config.js", "background.js"]
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
